{
  "name": "@codeagent-ui/codeagent",
  "version": "1.32.0",
  "description": "A web-based UI for AI coding agents",
  "type": "module",
  "main": "dist-server/server/index.js",
  "bin": {
    "codeagent": "dist-server/server/cli.js"
  },
  "files": [
    "server/",
    "shared/",
    "dist/",
    "dist-server/",
    "scripts/",
    "README.md",
    "codeagent"
  ],
  "homepage": "https://github.com/bighu630/claudecodeui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bighu630/claudecodeui.git"
  },
  "bugs": {
    "url": "https://github.com/bighu630/claudecodeui/issues"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"npm run server:dev\" \"npm run client\"",
    "server": "node dist-server/server/index.js",
    "server:dev": "tsx --tsconfig server/tsconfig.json server/index.js",
    "server:dev-watch": "tsx watch --tsconfig server/tsconfig.json server/index.js",
    "client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "prebuild:server": "node -e \"require('node:fs').rmSync('dist-server', { recursive: true, force: true })\"",
    "build:server": "tsc -p server/tsconfig.json && tsc-alias -p server/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.json",
    "lint": "eslint src/ server/",
    "lint:fix": "eslint src/ server/ --fix",
    "start": "npm run build && npm run server",
    "release": "./release.sh",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/fix-node-pty.js",
    "prepare": "husky",
    "update:platform": "./update-platform.sh"
  },
  "keywords": [
    "claude code",
    "claude-code",
    "claude-code-ui",
    "codex",
    "gemini",
    "gemini-cli",
    "cursor",
    "cursor-cli",
    "anthropic",
    "openai",
    "google",
    "coding-agent",
    "web-ui",
    "ui",
    "mobile IDE"
  ],
  "author": "CodeAgent UI Contributors",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@iarna/toml": "^2.2.5",
    "@octokit/rest": "^22.0.1",
    "@openai/codex-sdk": "0.134.0",
    "@replit/codemirror-minimap": "^0.5.2",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/react-codemirror": "^4.25.10",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "cross-spawn": "^7.0.6",
    "express": "^4.22.2",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "katex": "^0.16.47",
    "lucide-react": "^0.515.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.2.0-beta.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.4.1",
    "react-error-boundary": "^4.1.2",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "react-syntax-highlighter": "^15.6.6",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.4",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cross-spawn": "^6.0.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "auto-changelog": "^2.5.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-gyp": "^10.3.1",
    "postcss": "^8.5.15",
    "release-it": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": "eslint",
    "server/**/*.{js,ts}": "eslint"
  }
}
